# Per-user state — never in shared history (SQLite, LanceDB, logs, cursors)
state/*
!state/.gitkeep

# Per-user config (real copy); only config.example.yml is tracked. The live
# config lives in ~/.pr-residents/ by default; these cover in-repo dogfooding.
config/config.yml
config/user.yml
config/tokens/

# Secrets — env files, tokens
.env
*.pat
*.token

# Python
__pycache__/
*.pyc
.venv/
venv/
