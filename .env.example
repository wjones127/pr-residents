# Template for local secrets. Copy to .env (gitignored) and fill in.
# Load before running pr-sync by hand, e.g.:  set -a; source .env; set +a
# In the remote routine (slice 5), set these in the routine environment instead.

# Fine-grained PATs are single-owner, so use ONE read-only token per org.
# Naming convention: GITHUB_TOKEN_<ORG>, org upper-snake-cased
# (lance-format -> LANCE_FORMAT). pr-sync derives the var name from each
# repo's owner and selects the matching token.
GITHUB_TOKEN_LANCE_FORMAT=
GITHUB_TOKEN_LANCEDB=

# Embedding API key — only needed once pr-relevance lands (slice 4).
# ANTHROPIC_API_KEY=
