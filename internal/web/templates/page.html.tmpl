{{define "page"}}<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PR Rounds — {{.DateLabel}}</title>
  <style>{{css}}</style>
</head>
<body>
  <div class="wrap">
    <h1>PR Review Rounds</h1>
    <p class="sub"><b>{{.DateLabel}}</b> · <b>{{.Total}} PRs</b> — {{len .Fresh}} fresh · {{len .Rereview}} re-review · {{.HouseCount}} housekeeping</p>
    <div class="controls">
      <button id="refresh" type="button">↻ Refresh</button>
      <button id="triage" type="button">↻ Triage</button>
      <button id="dispatch" type="button">▶ Dispatch</button>
      <button id="cancel" type="button" class="cancel" hidden>■ Cancel</button>
      <div class="progress"><div id="bar"></div></div>
      <span id="status" class="pstatus"></span>
      <span id="tokens" class="tokens"></span>
    </div>
    <div id="lanes">{{template "lanes" .}}</div>
    <footer>Deterministic pre-assembly (pr-sync). Refresh re-fetches review-relevant PRs and re-derives lanes; Triage re-ranks self-requested candidates separately. No writes to GitHub.</footer>
  </div>
  <script>{{js}}</script>
</body>
</html>
{{end}}
